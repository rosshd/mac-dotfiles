    "terminal.ansiBrightGreen": "#A6E08C",
    "terminal.ansiBrightYellow": "#FFB454",
    "terminal.ansiBrightBlue": "#7AA2F7",
    "terminal.ansiBrightMagenta": "#CC8CF2",
    "terminal.ansiBrightCyan": "#7DCFFF",
    "terminal.ansiBrightWhite": "#F7EBD8",
    "terminalCursor.foreground": "#7DCFFF",
    "statusBar.background": "#0B1020",
    "statusBar.foreground": "#7DCFFF",
    "statusBar.border": "#00000000",
    "statusBar.debuggingBackground": "#292E42",
    "statusBar.debuggingForeground": "#C0CAF5",
    "statusBar.noFolderBackground": "#0B1020",
    "statusBarItem.hoverBackground": "#163149",
    "titleBar.activeBackground": "#0B1020",
