    "editorCursor.foreground": "#7DCFFF",
    "editor.selectionBackground": "#26324A",
    "editor.inactiveSelectionBackground": "#26324A80",
    "editor.selectionHighlightBackground": "#7DCFFF22",
    "editor.wordHighlightBackground": "#7AA2F722",
    "editor.wordHighlightStrongBackground": "#C78DF022",
    "editor.findMatchBackground": "#7AA2F755",
    "editor.findMatchBorder": "#7DCFFF",
    "editor.findMatchHighlightBackground": "#7DCFFF33",
    "editor.hoverHighlightBackground": "#7DCFFF18",
    "editor.lineHighlightBackground": "#151D2E",
    "editor.lineHighlightBorder": "#2F354D",
    "editorIndentGuide.background1": "#28334A",
    "editorIndentGuide.activeBackground1": "#7DCFFF77",
    "editorBracketMatch.background": "#7DCFFF22",
    "editorBracketMatch.border": "#7DCFFF",
    "editorGutter.background": "#111827",
    "editorGutter.modifiedBackground": "#7AA2F7",
    "editorGutter.addedBackground": "#A6E08C",
    "editorGutter.deletedBackground": "#FF7240",
    "editorOverviewRuler.border": "#0B1020",
    "editorOverviewRuler.findMatchForeground": "#7AA2F7AA",
    "editorOverviewRuler.modifiedForeground": "#7AA2F7AA",
    "editorOverviewRuler.addedForeground": "#A6E08CAA",
    "editorOverviewRuler.deletedForeground": "#FF7240AA",
    "panel.background": "#0B1020",
    "panel.border": "#00000000",
    "panelTitle.activeForeground": "#7DCFFF",
    "panelTitle.inactiveForeground": "#565F89",
    "panelTitle.activeBorder": "#7DCFFF",
    "terminal.background": "#0B1020",
    "terminal.foreground": "#C0CAF5",
    "terminal.ansiBlack": "#111827",
    "terminal.ansiRed": "#D9472E",
    "terminal.ansiGreen": "#7AB86B",
    "terminal.ansiYellow": "#F5A524",
    "terminal.ansiBlue": "#5A85D9",
    "terminal.ansiMagenta": "#9E61C7",
    "terminal.ansiCyan": "#58ADCC",
    "terminal.ansiWhite": "#C0CAF5",
