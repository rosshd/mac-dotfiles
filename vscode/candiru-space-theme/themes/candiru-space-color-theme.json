    "list.focusForeground": "#C0CAF5",
    "list.highlightForeground": "#7DCFFF",
    "list.hoverBackground": "#111A2B",
    "list.inactiveSelectionBackground": "#182033",
    "list.inactiveSelectionForeground": "#C0CAF5",
    "list.warningForeground": "#FFBE4D",
    "list.errorForeground": "#FF7240",
