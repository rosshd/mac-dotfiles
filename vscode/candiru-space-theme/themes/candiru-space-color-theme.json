    "gitDecoration.modifiedResourceForeground": "#7AA2F7",
    "gitDecoration.deletedResourceForeground": "#FF7240",
    "gitDecoration.untrackedResourceForeground": "#FFB454",
    "gitDecoration.ignoredResourceForeground": "#5B6270",
    "breadcrumb.background": "#0B1020BA",
    "breadcrumb.foreground": "#565F89",
    "breadcrumb.focusForeground": "#C0CAF5",
    "breadcrumb.activeSelectionForeground": "#7DCFFF",
    "peekView.border": "#7DCFFF",
    "peekViewEditor.background": "#0B1020",
    "peekViewResult.background": "#070B14",
    "peekViewTitle.background": "#0B1020",
    "tab.activeBorder": "#00000000",
    "tab.unfocusedActiveBorder": "#00000000",
    "breadcrumbPicker.background": "#0B1020F2",
    "titleBar.border": "#00000000",
    "activityBar.activeBorder": "#7DCFFF"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#88927F",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#A6E08C"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFBE4D"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#CC8CF2"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#7FD1EB"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#F7EBD8"
      }
    },
    {
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#F2C16B"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#85B3FF"
      }
    },
    {
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#FF9A57"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FFBE4D"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#B6BDAE"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFDDD2",
        "background": "#8A2418"
      }
    },
    {
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#FFBE4D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#FFE8B5"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#7FD1EB"
      }
    },
    {
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#A6E08C"
      }
    },
    {
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#FF7240"
      }
    },
    {
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#FFBE4D"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#85B3FF",
    "class": "#85B3FF",
    "enum": "#85B3FF",
    "interface": "#7FD1EB",
    "struct": "#85B3FF",
    "typeParameter": "#CC8CF2",
    "type": "#85B3FF",
    "parameter": "#F2C16B",
    "variable": "#F7EBD8",
    "property": "#FFF0C8",
    "enumMember": "#FFBE4D",
    "function": "#7FD1EB",
    "method": "#7FD1EB",
    "macro": "#FF9A57",
    "keyword": "#CC8CF2",
    "comment": {
      "foreground": "#88927F",
      "italic": true
    },
    "string": "#A6E08C",
    "number": "#FFBE4D",
    "regexp": "#58ADCC",
    "operator": "#CC8CF2",
    "decorator": "#FF9A57"
  }
}
